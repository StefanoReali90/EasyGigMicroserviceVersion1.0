{
  "name": "easygig-test-automation",
  "version": "1.0.0",
  "description": "EasyGIG E2E & API Test Automation Framework using Cucumber, Gherkin, Playwright and Allure Report",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "test": "tsc && node node_modules/@cucumber/cucumber/bin/cucumber-js --import ./dist/src/steps/auth.steps.js --import ./dist/src/steps/slots.steps.js --import ./dist/src/steps/bookings.steps.js --import ./dist/src/steps/ui.steps.js",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "keywords": [
    "playwright",
    "gherkin",
    "cucumber",
    "allure",
    "testing",
    "bdd",
    "easygig"
  ],
  "author": "EasyGIG Team",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.13.1",
    "allure-commandline": "^2.32.0",
    "allure-cucumberjs": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
